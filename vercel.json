{
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/daily-health-check",
      "schedule": "30 5 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
